    {
        "id": "86dc2507d09a5b90",
        "type": "function",
        "z": "e56366e249ffa3a8",
        "name": "Function Gerar linha CSV",
        "func": "let topico = (msg.topic || \"\").toLowerCase();\nlet valor = Number(msg.payload);\n\nlet dados = flow.get(\"dadosCSV\") || {};\n\nnode.status({\n    fill: \"blue\",\n    shape: \"dot\",\n    text: topico + \" = \" + valor\n});\n\nif (topico.includes(\"temperatura\")) {\n    dados.temperatura = valor;\n}\n\nelse if (topico.includes(\"umidade\") && topico.includes(\"solo\")) {\n    dados.umidadeSolo = valor;\n}\n\nelse if (topico.includes(\"umidade\")) {\n    dados.umidadeAr = valor;\n}\n\nelse if (topico.includes(\"luminosidade\")) {\n    dados.luminosidade = valor;\n}\n\nelse if (topico.includes(\"chuva\")) {\n    dados.chuva = valor;\n}\n\nflow.set(\"dadosCSV\", dados);\n\nif (\n    dados.temperatura !== undefined &&\n    dados.umidadeAr !== undefined &&\n    dados.umidadeSolo !== undefined &&\n    dados.luminosidade !== undefined &&\n    dados.chuva !== undefined\n) {\n    let data = new Date().toLocaleString(\"pt-BR\");\n\n    msg.payload =\n        data + \";\" +\n        dados.temperatura + \";\" +\n        dados.umidadeAr + \";\" +\n        dados.umidadeSolo + \";\" +\n        dados.luminosidade + \";\" +\n        dados.chuva;\n\n    return msg;\n}\n\nnode.warn(\"Aguardando todos os sensores. Recebidos até agora: \" + JSON.stringify(dados));\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1070,
        "y": 720,
        "wires": [
