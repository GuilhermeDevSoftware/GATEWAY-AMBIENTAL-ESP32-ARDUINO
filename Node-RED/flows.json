        "func": "let linhas = msg.payload;\n\nif (!linhas || linhas.length === 0) {\n    msg.payload = \"Nenhum registro encontrado no banco.\";\n    return msg;\n}\n\nlet texto = \"Últimas leituras salvas no SQLite:\\n\\n\";\n\nlinhas.forEach((linha) => {\n    texto += `ID: ${linha.id}\\n`;\n    texto += `Data/Hora: ${linha.data_hora}\\n`;\n    texto += `Temperatura: ${linha.temperatura} °C\\n`;\n    texto += `Umidade do ar: ${linha.umidade_ar} %\\n`;\n    texto += `Umidade do solo: ${linha.umidade_solo}\\n`;\n    texto += `Luminosidade: ${linha.luminosidade}\\n`;\n    texto += `Chuva: ${linha.chuva}\\n`;\n    texto += \"-------------------------\\n\";\n});\n\nmsg.payload = texto;\nreturn msg;",
