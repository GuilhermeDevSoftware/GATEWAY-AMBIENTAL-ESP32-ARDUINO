    {
        "id": "561c17d8cf3c63fd",
        "type": "function",
        "z": "e56366e249ffa3a8",
        "name": "Salvar no SQLite",
        "func": "let dados = msg.payload;\n\n// Garante que está usando apenas o tópico correto\nif (msg.topic !== \"gateway/ambiental/dados\") {\n    return null;\n}\n\n// Caso o payload venha como texto JSON, converte para objeto\nif (typeof dados === \"string\") {\n    try {\n        dados = JSON.parse(dados);\n    } catch (erro) {\n        node.status({\n            fill: \"red\",\n            shape: \"ring\",\n            text: \"JSON inválido\"\n        });\n        return null;\n    }\n}\n\n// Verifica se veio como objeto\nif (typeof dados !== \"object\" || dados === null) {\n    node.status({\n        fill: \"red\",\n        shape: \"ring\",\n        text: \"payload inválido\"\n    });\n    return null;\n}\n\n// Converte os valores\nlet temperatura = Number(dados.temperatura);\nlet umidade_ar = Number(dados.umidade_ar);\nlet umidade_solo = Number(dados.umidade_solo);\nlet luminosidade = Number(dados.luminosidade);\nlet chuva = Number(dados.chuva);\n\n// Validação\nif (\n    isNaN(temperatura) ||\n    isNaN(umidade_ar) ||\n    isNaN(umidade_solo) ||\n    isNaN(luminosidade) ||\n    isNaN(chuva)\n) {\n    node.status({\n        fill: \"red\",\n        shape: \"ring\",\n        text: \"dados inválidos\"\n    });\n\n    node.warn(dados);\n    return null;\n}\n\n// Gera o comando SQL\nmsg.topic = `\nINSERT INTO leituras (\n    temperatura,\n    umidade_ar,\n    umidade_solo,\n    luminosidade,\n    chuva\n) VALUES (\n    ${temperatura},\n    ${umidade_ar},\n    ${umidade_solo},\n    ${luminosidade},\n    ${chuva}\n);\n`;\n\nnode.status({\n    fill: \"green\",\n    shape: \"dot\",\n    text: \"enviado ao SQLite\"\n});\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
