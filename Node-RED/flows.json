    {
        "id": "57d317c8b2171882",
        "type": "function",
        "z": "e56366e249ffa3a8",
        "name": "Verificar alertas",
        "func": "// Pega o tópico MQTT e o valor recebido\nlet topico = msg.topic;\nlet valor = Number(msg.payload);\n\n// Recupera os últimos dados salvos\nlet dados = flow.get(\"dadosSensores\") || {};\n\n// Identifica qual sensor chegou pelo tópico\nif (topico.includes(\"temperatura\")) {\n    dados.temperatura = valor;\n}\n\nif (topico.includes(\"umidade_ar\") || topico.includes(\"umidadear\") || topico.includes(\"umidade\")) {\n    dados.umidadeAr = valor;\n}\n\nif (topico.includes(\"solo\")) {\n    dados.umidadeSolo = valor;\n}\n\nif (topico.includes(\"luminosidade\") || topico.includes(\"luz\")) {\n    dados.luminosidade = valor;\n}\n\nif (topico.includes(\"chuva\")) {\n    dados.chuva = valor;\n}\n\n// Salva os dados atualizados\nflow.set(\"dadosSensores\", dados);\n\n// Se ainda não recebeu todos os sensores, mostra aguardando\nif (\n    dados.temperatura === undefined ||\n    dados.umidadeAr === undefined ||\n    dados.umidadeSolo === undefined ||\n    dados.luminosidade === undefined ||\n    dados.chuva === undefined\n) {\n    let msgStatus = {\n        payload: \"Aguardando dados de todos os sensores...\"\n    };\n\n    return [msgStatus, null];\n}\n\n// Limites de alerta\nlet limiteTemperaturaAlta = 30;\nlet limiteUmidadeArBaixa = 40;\nlet limiteSoloSeco = 900;\nlet limitePoucaLuz = 300;\nlet limiteChuvaDetectada = 700;\n\n// Lista de alertas\nlet alertas = [];\n\nif (dados.temperatura > limiteTemperaturaAlta) {\n    alertas.push(\"Temperatura alta: \" + dados.temperatura + \" °C\");\n}\n\nif (dados.umidadeAr < limiteUmidadeArBaixa) {\n    alertas.push(\"Umidade do ar baixa: \" + dados.umidadeAr + \" %\");\n}\n\nif (dados.umidadeSolo > limiteSoloSeco) {\n    alertas.push(\"Solo seco: \" + dados.umidadeSolo);\n}\n\nif (dados.luminosidade < limitePoucaLuz) {\n    alertas.push(\"Pouca luminosidade: \" + dados.luminosidade);\n}\n\nif (dados.chuva < limiteChuvaDetectada) {\n    alertas.push(\"Chuva detectada: \" + dados.chuva);\n}\n\n// Mensagem para o dashboard text\nlet msgStatus = {\n    payload: alertas.length === 0\n        ? \"Sistema normal - nenhum alerta ativo\"\n        : \"ALERTA: \" + alertas.join(\" | \")\n};\n\n// Mensagem para debug/notificação\nlet msgAlerta = null;\n\nif (alertas.length > 0) {\n    msgAlerta = {\n        payload: alertas.join(\" | \"),\n        topic: \"Alerta Gateway Ambiental\",\n        dados: dados,\n        horario: new Date().toLocaleString(\"pt-BR\")\n    };\n}\n\nreturn [msgStatus, msgAlerta];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1060,
        "y": 920,
        "wires": [
